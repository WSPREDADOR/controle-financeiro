{
    "name":  "controle-financeiro",
    "version":  "1.4.50",
    "description":  "Aplicativo desktop para controle de compromissos e pagamentos.",
    "main":  "main.js",
    "author":  {
                   "name":  "Werbert Silva"
               },
    "license":  "MIT",
    "scripts":  {
                    "prepare:assets":  "node scripts/generate-icons.js",
                    "build:web":  "npm run prepare:assets \u0026\u0026 node scripts/generate-web-bundle.js \u0026\u0026 node scripts/build-mobile-web.js",
                    "start":  "npm run prepare:assets \u0026\u0026 electron .",
                    "dist:win":  "npm run prepare:assets \u0026\u0026 electron-builder --win nsis",
                    "mobile:assets":  "node scripts/generate-android-assets.js",
                    "mobile:sync":  "npm run build:web \u0026\u0026 npx cap sync android \u0026\u0026 npm run mobile:assets",
                    "mobile:android":  "npm run mobile:sync \u0026\u0026 npx cap open android",
                    "release":  "node scripts/release.js"
                },
    "dependencies":  {
                         "@capacitor/android":  "^7.1.0",
                         "@capacitor/core":  "^7.1.0",
                         "@capacitor/local-notifications":  "^7.0.6",
                         "@capacitor/preferences":  "^8.0.1"
                     },
    "devDependencies":  {
                            "@capacitor/cli":  "^7.1.0",
                            "electron":  "^36.3.2",
                            "electron-builder":  "^26.0.12",
                            "png-to-ico":  "^2.1.8",
                            "sharp":  "^0.34.2"
                        },
    "build":  {
                  "appId":  "com.werbertsilva.controlefinanceiro",
                  "productName":  "Controle Financeiro",
                  "copyright":  "Copyright © 2026 Werbert Silva",
                  "artifactName":  "${productName} Setup ${version}.${ext}",
                  "directories":  {
                                      "buildResources":  "build",
                                      "output":  "release"
                                  },
                  "files":  [
                                "index.html",
                                "splash.html",
                                "style.css",
                                "script.js",
                                "main.js",
                                "build/**/*",
                                "package.json"
                            ],
                  "win":  {
                              "executableName":  "Controle Financeiro",
                              "target":  [
                                             {
                                                 "target":  "nsis",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ],
                              "icon":  "build/icon.ico"
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "createDesktopShortcut":  true,
                               "createStartMenuShortcut":  true,
                               "shortcutName":  "Controle Financeiro",
                               "installerIcon":  "build/icon.ico",
                               "uninstallerIcon":  "build/icon.ico",
                               "installerHeaderIcon":  "build/icon.ico"
                           }
              }
}
