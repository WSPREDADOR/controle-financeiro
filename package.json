{
  "name": "controle-financeiro",
  "version": "2.3.7",
  "description": "Aplicativo desktop para controle de compromissos e pagamentos.",
  "main": "main.js",
  "author": {
    "name": "Werbert Silva"
  },
  "license": "MIT",
  "scripts": {
    "prepare:assets": "node scripts/generate-icons.js",
    "build:web": "npm run prepare:assets && node scripts/generate-web-bundle.js && node scripts/build-mobile-web.js",
    "start": "npm run prepare:assets && electron .",
    "dist:win": "npm run prepare:assets && electron-builder --win nsis",
    "mobile:assets": "node scripts/generate-android-assets.js",
    "mobile:sync": "npm run build:web && npx cap sync android && npm run mobile:assets",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js --patch",
    "release:minor": "node scripts/release.js --minor",
    "release:major": "node scripts/release.js --major"
  },
  "dependencies": {
    "@capacitor/android": "^7.1.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.1.0",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/local-notifications": "^7.0.6",
    "@capacitor/preferences": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.1.0",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.2"
  },
  "build": {
    "appId": "com.werbertsilva.controlefinanceiro",
    "productName": "Controle de Dívidas",
    "copyright": "Copyright © 2026 Werbert Silva",
    "artifactName": "${productName} Setup ${version}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "index.html",
      "splash.html",
      "style.css",
      "script.js",
      "main.js",
      "build/**/*",
      "package.json"
    ],
    "win": {
      "executableName": "Controle de Dívidas",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Controle de Dívidas",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
